<UserControl x:Class="OPSW11.Views.QuickFixView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1000">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <StackPanel Margin="32,28,32,28">

            <TextBlock Text="Szybka naprawa"
                       Style="{StaticResource HeadingXL}" Margin="0,0,0,4"/>
            <TextBlock Text="Wykonuje bezpieczne operacje bez konieczności restartu."
                       Style="{StaticResource BodyText}" Margin="0,0,0,24"/>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="WYKONA:" Style="{StaticResource CaptionText}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource InputBackground}"
                                CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Czyszczenie plików tymczasowych" Style="{StaticResource HeadingM}" Margin="0,0,0,4"/>
                                <TextBlock Text="Usuwa zawartość %TEMP% i C:\Windows\Temp."
                                           Style="{StaticResource BodyText}" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource InputBackground}"
                                CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Czyszczenie Prefetch" Style="{StaticResource HeadingM}" Margin="0,0,0,4"/>
                                <TextBlock Text="Opróżnia pamięć podręczną Prefetch dla szybszego startu."
                                           Style="{StaticResource BodyText}" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource InputBackground}"
                                CornerRadius="8" Padding="14,12" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Reset cache DNS" Style="{StaticResource HeadingM}" Margin="0,0,0,4"/>
                                <TextBlock Text="Czyści cache resolwera DNS — naprawia błędne adresy."
                                           Style="{StaticResource BodyText}" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="2" Background="{DynamicResource InputBackground}"
                                CornerRadius="8" Padding="14,12" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Cache Windows Update" Style="{StaticResource HeadingM}" Margin="0,0,0,4"/>
                                <TextBlock Text="Zatrzymuje usługi WU i czyści folder pobierania."
                                           Style="{StaticResource BodyText}" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Button x:Name="RunButton"
                    Content="URUCHOM SZYBKĄ NAPRAWĘ"
                    Style="{StaticResource PrimaryButton}"
                    FontSize="14" Padding="0,14"
                    HorizontalAlignment="Stretch"
                    Click="RunButton_Click"/>

            <Border x:Name="ProgressPanel" Style="{StaticResource Card}"
                    Margin="0,16,0,0" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="POSTĘP" Style="{StaticResource CaptionText}" Margin="0,0,0,12"/>
                    <ProgressBar x:Name="OverallProgress" Value="0" Maximum="5" Height="6" Margin="0,12,0,0"/>
                    <TextBlock x:Name="CurrentOperationText"
                               Text="Uruchamianie..."
                               Style="{StaticResource BodyText}" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="OperationStatusList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,3" FontFamily="Consolas, Courier New"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
