<UserControl x:Class="OPSW11.Views.CustomFixView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Background="Transparent">
            <StackPanel Margin="32,28,32,16">

                <TextBlock Text="Naprawa własna"
                           Style="{StaticResource HeadingXL}" Margin="0,0,0,4"/>
                <TextBlock Text="Zaznacz operacje do wykonania i kliknij Uruchom wybrane."
                           Style="{StaticResource BodyText}" Margin="0,0,0,24"/>

                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="CZYSZCZENIE" Style="{StaticResource CaptionText}" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="CleanupOpsPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="0,5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="SIEĆ" Style="{StaticResource CaptionText}" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="NetworkOpsPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="0,5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="NAPRAWA SYSTEMU" Style="{StaticResource CaptionText}" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="RepairOpsPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="0,5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="USŁUGI" Style="{StaticResource CaptionText}" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="ServicesOpsPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="0,5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="DYSK" Style="{StaticResource CaptionText}" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="DiskOpsPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="0,5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border x:Name="ProgressPanel" Style="{StaticResource Card}"
                        Margin="0,0,0,0" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="POSTĘP" Style="{StaticResource CaptionText}" Margin="0,0,0,8"/>
                        <ProgressBar x:Name="ProgressBar" Value="0" Maximum="1" Height="6" Margin="0,0,0,10"/>
                        <TextBlock x:Name="CurrentOpText" Text=""
                                   Style="{StaticResource BodyText}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="ResultText" Text=""
                                   Style="{StaticResource BodyText}" FontSize="12"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="{DynamicResource StatusBarBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0"
                          x:Name="SafeModeCheckBox"
                          IsChecked="False"
                          Margin="0,0,16,0"
                          VerticalAlignment="Center"
                          Checked="SafeMode_Changed" Unchecked="SafeMode_Changed">
                    <TextBlock Text="Tylko bezpieczne operacje"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </CheckBox>

                <Button Grid.Column="1"
                        Content="Zaznacz wszystko"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,7" FontSize="12"
                        Click="SelectAll_Click"/>

                <TextBlock Grid.Column="2"
                           x:Name="SelectionCountText"
                           Text="0 operacji wybranych"
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <Button Grid.Column="3"
                        x:Name="CancelButton"
                        Content="Anuluj"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,7" Margin="0,0,8,0"
                        Visibility="Collapsed"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="4"
                        x:Name="RunSelectedButton"
                        Content="Uruchom wybrane"
                        Style="{StaticResource PrimaryButton}"
                        IsEnabled="False"
                        Click="RunSelected_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
