<UserControl x:Class="OPSW11.Views.AdvancedFixView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1000">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <StackPanel Margin="32,28,32,28">

            <TextBlock Text="Zaawansowana naprawa"
                       Style="{StaticResource HeadingXL}" Margin="0,0,0,4"/>
            <TextBlock Text="Uruchamia SFC, DISM i resetuje składniki Windows Update."
                       Style="{StaticResource BodyText}" Margin="0,0,0,16"/>

            <Border Background="{DynamicResource WarnBannerBg}"
                    BorderBrush="{DynamicResource WarningBrush}"
                    BorderThickness="1" CornerRadius="9"
                    Padding="16,12" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8C9;" FontFamily="Segoe MDL2 Assets"
                               FontSize="18" Foreground="{DynamicResource WarningBrush}"
                               Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Wymagany restart po zakończeniu"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock Text="Zapisz wszystkie otwarte pliki przed uruchomieniem tej operacji."
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="OPERACJE" Style="{StaticResource CaptionText}" Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource AccentSubtle}"
                                CornerRadius="5" Width="22" Height="22" VerticalAlignment="Top" Margin="0,1,0,0">
                            <TextBlock Text="1" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="SFC /scannow — Sprawdzenie plików systemowych"
                                       Style="{StaticResource HeadingM}" Margin="0,0,0,3"/>
                            <TextBlock Text="Skanuje i naprawia uszkodzone pliki chronionych zasobów systemu Windows."
                                       Style="{StaticResource BodyText}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource AccentSubtle}"
                                CornerRadius="5" Width="22" Height="22" VerticalAlignment="Top" Margin="0,1,0,0">
                            <TextBlock Text="2" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="DISM /RestoreHealth — Naprawa obrazu systemu"
                                       Style="{StaticResource HeadingM}" Margin="0,0,0,3"/>
                            <TextBlock Text="Sprawdza i przywraca magazyn komponentów systemu Windows."
                                       Style="{StaticResource BodyText}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource AccentSubtle}"
                                CornerRadius="5" Width="22" Height="22" VerticalAlignment="Top" Margin="0,1,0,0">
                            <TextBlock Text="3" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Reset składników Windows Update"
                                       Style="{StaticResource HeadingM}" Margin="0,0,0,3"/>
                            <TextBlock Text="Zatrzymuje usługi WU, czyści cache SoftwareDistribution i rejestruje DLL-e."
                                       Style="{StaticResource BodyText}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource AccentSubtle}"
                                CornerRadius="5" Width="22" Height="22" VerticalAlignment="Top" Margin="0,1,0,0">
                            <TextBlock Text="4" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Reset stosu sieciowego (netsh)"
                                       Style="{StaticResource HeadingM}" Margin="0,0,0,3"/>
                            <TextBlock Text="Resetuje stos TCP/IP i ustawienia Winsock."
                                       Style="{StaticResource BodyText}" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardCompact}" Margin="0,0,0,16">
                <TextBlock Text="Skanowanie SFC i DISM może potrwać 15–45 minut w zależności od rozmiaru dysku."
                           Style="{StaticResource BodyText}" FontSize="12"/>
            </Border>

            <Border Background="{DynamicResource SuccessBannerBg}"
                    BorderBrush="{DynamicResource SuccessBrush}"
                    BorderThickness="1" CornerRadius="9"
                    Padding="16,12" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE83D;" FontFamily="Segoe MDL2 Assets"
                               FontSize="15" Foreground="{DynamicResource SuccessBrush}"
                               Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Przed uruchomieniem zostanie automatycznie utworzony punkt przywracania systemu."
                               Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Button x:Name="CancelButton"
                    Content="Anuluj"
                    Style="{StaticResource SecondaryButton}"
                    Padding="0,14" FontSize="14"
                    HorizontalAlignment="Stretch"
                    Visibility="Collapsed"
                    Margin="0,8,0,0"
                    Click="CancelButton_Click"/>

            <Button x:Name="RunButton"
                    Content="URUCHOM ZAAWANSOWANĄ NAPRAWĘ"
                    Style="{StaticResource PrimaryButton}"
                    FontSize="14" Padding="0,14"
                    HorizontalAlignment="Stretch"
                    Click="RunButton_Click"/>

            <Border x:Name="ProgressPanel" Style="{StaticResource Card}"
                    Margin="0,16,0,0" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="POSTĘP" Style="{StaticResource CaptionText}" Margin="0,0,0,8"/>
                    <ProgressBar x:Name="OverallProgress" Value="0" Maximum="4" Height="6" Margin="0,0,0,12"/>
                    <TextBlock x:Name="CurrentOpText" Text=""
                               Style="{StaticResource BodyText}" Margin="0,0,0,8"/>
                    <TextBlock Text="WYNIK NA ŻYWO" Style="{StaticResource CaptionText}" Margin="0,0,0,6"/>
                    <Border Background="{DynamicResource InputBackground}"
                            CornerRadius="7" Padding="12" MaxHeight="220">
                        <ScrollViewer x:Name="OutputScroll" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="LiveOutputText"
                                       FontFamily="Consolas, Courier New" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

            <Border x:Name="RestartBanner" Background="{DynamicResource WarnBannerBg}"
                    BorderBrush="{DynamicResource WarningBrush}"
                    BorderThickness="1" CornerRadius="9"
                    Padding="16,12" Margin="0,16,0,0" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Foreground="{DynamicResource WarningBrush}"
                                   Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Operacje zakończone — uruchom ponownie komputer, aby zastosować zmiany."
                                   Foreground="{DynamicResource WarningBrush}"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            x:Name="RestartButton"
                            Content="Uruchom ponownie"
                            Style="{StaticResource DangerButton}"
                            Padding="14,8" Margin="12,0,0,0"
                            Click="RestartNowButton_Click"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
